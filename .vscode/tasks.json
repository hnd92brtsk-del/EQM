{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "EQM: Install Backend Dependencies",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "backend\\requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "EQM: Install Frontend Dependencies",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "EQM: Alembic Upgrade Head",
      "type": "shell",
      "command": "..\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "alembic",
        "upgrade",
        "head"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "problemMatcher": []
    },
    {
      "label": "EQM: Seed Database",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "backend\\scripts\\seed.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "EQM: Run Backend",
      "type": "shell",
      "command": "..\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "app.main:app",
        "--reload",
        "--host",
        "localhost",
        "--port",
        "8000"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "EQM: Run Frontend",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
