DB_HOST=localhost
DB_PORT=5432
DB_NAME=equipment_crm
DB_USER=equipment_user
DB_PASSWORD=change_me
POSTGRES_SUPERUSER_PASSWORD=change_me

JWT_SECRET=change_this_to_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=5
ENV=development
CORS_ALLOW_ORIGINS=http://localhost:5173

# Пути можно задавать относительными от корня репозитория или абсолютными.
PHOTO_DIR=Photo
DATASHEET_DIR=Datasheets
UPLOAD_DIR=backend/uploads
CABINET_FILES_DIR=backend/storage/cabinet_files
PID_STORAGE_ROOT=backend/app/pid_storage
CABINET_FILES_MAX_SIZE=10737418240

# Основные переменные для LLM.
LLM_BASE_URL=http://localhost:1234
LLM_API_KEY=
LLM_MODEL=phi3-mini-4k-instruct

# Устаревшие алиасы оставлены для совместимости.
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_API_KEY=
