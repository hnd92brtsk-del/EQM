# Роли и адреса серверов
EQM_APP_HOSTNAME=eqm-app-01
EQM_APP_IP=192.168.10.20
EQM_LLM_HOSTNAME=eqm-llm-01
EQM_LLM_IP=192.168.10.21

# PostgreSQL
DB_NAME=equipment_crm
DB_USER=equipment_user
DB_PASSWORD=change_me
POSTGRES_SUPERUSER_PASSWORD=change_me
POSTGRES_DATA_DIR=/srv/eqm-data/postgres

# Backend
DB_HOST=postgres
DB_PORT=5432
JWT_SECRET=change_this_to_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
ENV=production
CORS_ALLOW_ORIGINS=http://eqm-app-01,http://192.168.10.20
PHOTO_DIR=/srv/eqm-data/photo
DATASHEET_DIR=/srv/eqm-data/datasheets
UPLOAD_DIR=/srv/eqm-data/uploads
CABINET_FILES_DIR=/srv/eqm-data/cabinet-files
PID_STORAGE_ROOT=/srv/eqm-data/pid
CABINET_FILES_MAX_SIZE=10737418240
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345

# LLM
# Допустимы оба варианта: http://eqm-llm-01:1234 и http://eqm-llm-01:1234/v1
LLM_BASE_URL=http://eqm-llm-01:1234/v1
LLM_API_KEY=
LLM_MODEL=phi3-mini-4k-instruct

# Frontend build
VITE_API_URL=/api/v1
